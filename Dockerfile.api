FROM node:22-alpine
WORKDIR /app/server
ENV NODE_ENV=production
COPY server/package.json ./
RUN npm install --omit=dev
COPY server/index.mjs ./index.mjs
COPY lib /app/lib
COPY supabase/functions/ai-assessment-api/_shared /app/supabase/functions/ai-assessment-api/_shared
EXPOSE 3001
CMD ["node", "index.mjs"]

